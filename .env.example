APP_NAME=shop-agent-backend
APP_ENV=dev
API_V1_STR=/api/v1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=shop_user
MYSQL_PASSWORD=shop_pass
MYSQL_DB=shop_db

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=shop-agent

REDIS_KEY_PREFIX=shop
LOGIN_RATE_LIMIT_COUNT=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
ORDER_RATE_LIMIT_COUNT=20
ORDER_RATE_LIMIT_WINDOW_SECONDS=60
SUPPORT_VECTOR_STORE=chroma
SUPPORT_CHROMA_PERSIST_DIR=./data/chroma
SUPPORT_CHROMA_COLLECTION=support_kb_chunks
SUPPORT_RETRIEVAL_TOP_K=5

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2
